<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.1</TargetFramework>
		<LangVersion>latest</LangVersion>
		<Nullable>enable</Nullable>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>

		<PackageId>OXEMO.Paynow.Sdk</PackageId>
		<Version>1.0.3</Version>
		<Authors>KRML</Authors>
		<Company>OXEMO</Company>
		<Product>Paynow .NET SDK</Product>
		<PackageReleaseNotes>Dopasowano tokenizację kart do aktualnej dokumentacji Paynow: poprawiono endpointy metod płatności i usuwania karty, dodano SavedInstruments (tokeny kart) oraz uodporniono deserializację liczb. Dodano GetPaymentDetailsAsync(string) i zaktualizowano README.md.</PackageReleaseNotes>
		<Description>Nieoficjalne SDK dla bramki płatniczej Paynow (mBank/mElements) dla .NET. Obsługuje API v3.</Description>
		<PackageTags>paynow;payments;bramka;płatności;sdk;dotnet</PackageTags>

		<RepositoryUrl>https://github.com/OXEMO/OXEMO.Paynow.Sdk</RepositoryUrl>
		<RepositoryType>git</RepositoryType>

		<PackageLicenseExpression>MIT</PackageLicenseExpression>

		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>
	<ItemGroup>
	  <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.1" />
	  <PackageReference Include="System.Net.Http.Json" Version="8.0.1" />
	  <PackageReference Include="System.Text.Json" Version="8.0.6" />
	</ItemGroup>
	<ItemGroup>
		<None Include="..\README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>